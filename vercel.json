{
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://owldiary.onrender.com/api/:path*"
    },
    {
      "source": "/uploads/:path*",
      "destination": "https://owldiary.onrender.com/uploads/:path*"
    },
    {
      "source": "/((?!api/|uploads/).*)",
      "destination": "/"
    }
  ]
}
